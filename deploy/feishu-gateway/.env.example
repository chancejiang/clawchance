# Feishu App Configuration
# Get these from https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ZeroClaw Webhook URL
# The URL where ZeroClaw AI service is running
# Default: http://127.0.0.1:42617/webhook
ZEROCLAW_WEBHOOK_URL=http://127.0.0.1:42617/webhook

# Log Level
# Options: debug, info (default: info)
LOG_LEVEL=info
